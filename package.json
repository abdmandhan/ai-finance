{
  "name": "@tigeri/graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "setup:db": "tsx src/scripts/setup-db.ts",
    "seed:goal": "tsx src/scripts/seed-goal.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run --config evals/vitest.config.ts",
    "eval:watch": "vitest --config evals/vitest.config.ts",
    "allure:report": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:eval": "allure serve allure-results-eval",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "graph:dev": "langgraphjs dev"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.9.1",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-checkpoint": "^1.1.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@langchain/langgraph-checkpoint-redis": "^1.0.10",
    "@langchain/openai": "^1.5.3",
    "groupmq": "^1.1.0",
    "ioredis": "^5.11.1",
    "langchain": "^1.5.2",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "smol-toml": "^1.7.0",
    "zod": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@confluentinc/kafka-javascript"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@langchain/langgraph-cli": "^1.4.0",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@vitest/runner": "4.1.10",
    "allure": "^3.14.3",
    "allure-vitest": "^3.10.2",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
