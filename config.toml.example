[log]
format = "pretty" # "json" or "pretty"
level = "info"

[llm]
# Chat models used by the planner / entity-extraction nodes, in three size tiers.
# Shared defaults here; each tier may override url/api_key. model is
# "provider:model" (initChatModel format), e.g. "anthropic:claude-sonnet-4-5-20250929"
# or "openai:gpt-4o-mini".
url = ""              # optional OpenAI-compatible base URL; leave empty for hosted providers (Anthropic rejects it)
api_key = ""          # key matching the tier's provider

[llm.small]           # cheap/fast: classification, simple extraction
model = "anthropic:claude-haiku-4-5"

[llm.medium]          # default for structured extraction
model = "anthropic:claude-sonnet-4-5-20250929"

[llm.large]           # planner / conversational turns
model = "anthropic:claude-sonnet-4-5-20250929"

[redis]
# Redis powers the hot checkpointer tier and the queue pipeline.
# Empty url -> both off: checkpointer falls back to Postgres/MemorySaver,
# queue-backed consumption unavailable (worker.enabled must stay false).
url = ""              # e.g. "redis://localhost:6379"
password = ""

[worker]
# Queue-backed consumption: Kafka -> dedup -> Redis groupmq queue -> N workers.
# Requires redis.url. false -> direct Kafka -> handler (current simple path).
enabled = false
keep_completed = 100  # finished jobs retained in Redis
keep_failed = 300
concurrency = 10      # parallel jobs across chat groups (per-chat stays FIFO)
# Pause Kafka intake while waiting+active+delayed >= this. Keep small: the wait
# blocks the consumer poll loop, which must stay under librdkafka
# max.poll.interval.ms (5 min) or the consumer is kicked from the group.
max_backlog = 10
max_attempts = 3      # job retries before dead-lettering to kafka.topics.inbound_error
job_timeout_ms = 300000

[assistant]
# Hybrid assistant: a conversational main agent (thread assistant:<chatId>) answers general
# questions directly and calls the strict workflow graphs as tools.
# false -> rollback to the legacy classify() router (unsupported messages get no reply).
enabled = true
# Cap on prior conversation messages replayed to the model each turn.
max_history_messages = 30

[database]
# Postgres connection string for the durable LangGraph checkpointer.
# Leave empty to fall back to an in-memory checkpointer (dev only, no pause/resume durability).
url = "postgres://tigerscale:tigerscale@localhost:5432/tigerscale?sslmode=disable"

[calendar]
# Backend endpoint that mints per-tenant Google access tokens for Calendar + Drive (contacts).
# GET {base}/api/v1/internal/calendar/access?tenantId=<id>  ->  { accessToken, provider, calendarId, emailAddress, expiresAt }
token_endpoint_base_url = "http://localhost:8080"
# IANA timezone used to resolve relative times ("tomorrow at 10") when the message states none.
default_timezone = "Asia/Jakarta"
# Google Maps Distance Matrix key for travel-time between back-to-back meetings.
# Empty -> travel checks disabled (buffer-only). Falls back to OPENCLAW_MAPS_API_KEY env.
maps_api_key = ""
# Buffer kept before/after each meeting, and default working hours (local, default_timezone).
buffer_minutes = 15
working_hours_start = 9
working_hours_end = 18

[xero]
# Backend endpoint that mints per-tenant Xero access tokens.
# GET {base}/api/v1/internal/xero/access?tenantId=<id>  ->  { accessToken, xeroTenantId, apiBaseUrl, expiresAt }
token_endpoint_base_url = "http://localhost:8080"
# Optional org-default overrides so DRAFT invoices are authorise-ready (else auto-picked from Xero).
default_tax_type = ""
default_expense_account_code = ""
default_revenue_account_code = ""

[agents]
# Backend endpoint that resolves per-tenant/per-member agent enablement. Used to gate a
# disabled/paused agent (Scheduling / Invoicing) before its workflow runs.
# GET {base}/api/v1/internal/agents/enablement?chatId=<id>  ->  { agents: { scheduling, invoicing, expense } }
# On error the gate fails CLOSED (agent treated as disabled), so point this at a reachable backend.
enablement_endpoint_base_url = "http://localhost:8080"

[kafka]
url = "localhost:9092"
group_id = "tigeri-graph"
sasl_enable = false
sasl_username = ""
sasl_password = ""
sasl_mechanism = "PLAIN"
sasl_protocol = "SASL_SSL"

# The three real topics — the entire App<->Agent contract. chatId is the message key
[kafka.topics]
inbound = "chat.inbound"    # consume: user messages (new goals AND resume replies)
outbound = "chat.outbound"  # produce: AI replies, clarifications, approval requests (output.approvalData)
events = "chat.events"      # produce: ephemeral progress { stage, msg, timestamp }
inbound_error = "chat.inbound.error"  # produce: { error, data } dead-letter for failed inbound handling
